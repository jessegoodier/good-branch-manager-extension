{
  "name": "good-branch-manager",
  "version": "0.1.27",
  "description": "Simple git branch view: sync status at a glance, branch actions, and GitHub pull requests from the Source Control sidebar.",
  "homepage": "https://github.com/jessegoodier/good-branch-manager-extension#readme",
  "publisher": "JesseGoodier",
  "icon": "good-branch-manager.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jessegoodier/good-branch-manager-extension.git"
  },
  "license": "MIT",
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "bugs": {
    "url": "https://github.com/jessegoodier/good-branch-manager-extension/issues"
  },
  "categories": [
    "SCM Providers"
  ],
  "contributes": {
    "commands": [
      {
        "category": "Branches",
        "command": "goodBranchManager.refresh",
        "icon": "$(refresh)",
        "title": "Refresh Branches"
      },
      {
        "category": "Branches",
        "command": "goodBranchManager.checkout",
        "title": "Checkout Branch"
      },
      {
        "category": "Branches",
        "command": "goodBranchManager.createBranchFrom",
        "title": "Create Branch From This..."
      },
      {
        "category": "Branches",
        "command": "goodBranchManager.openOnGitHub",
        "enablement": "viewItem =~ /upstream|remote/",
        "title": "Open Branch on GitHub"
      },
      {
        "category": "Branches",
        "command": "goodBranchManager.createPullRequest",
        "title": "Create Pull Request..."
      },
      {
        "category": "Branches",
        "command": "goodBranchManager.renameBranch",
        "title": "Rename Branch..."
      },
      {
        "category": "Branches",
        "command": "goodBranchManager.mergeIntoCurrent",
        "title": "Merge Into Current Branch"
      },
      {
        "category": "Branches",
        "command": "goodBranchManager.deleteBranch",
        "title": "Delete Branch..."
      },
      {
        "category": "Branches",
        "command": "goodBranchManager.pullBranch",
        "title": "Pull..."
      },
      {
        "category": "Branches",
        "command": "goodBranchManager.setUpstream",
        "title": "Set Upstream..."
      },
      {
        "category": "Branches",
        "command": "goodBranchManager.unsetUpstream",
        "title": "Remove Upstream..."
      },
      {
        "category": "Branches",
        "command": "goodBranchManager.openPullRequest",
        "title": "Open Pull Request on GitHub"
      }
    ],
    "configuration": {
      "properties": {
        "goodBranchManager.branchScope": {
          "default": "both",
          "description": "Which branches to show in the Branches view.",
          "enum": [
            "both",
            "local"
          ],
          "enumDescriptions": [
            "Show local branches and remote branches in two collapsible groups.",
            "Show only local branches."
          ],
          "type": "string"
        },
        "goodBranchManager.staleAfterDays": {
          "default": 10,
          "description": "Mark a branch as stale when its last commit is older than this many days. Set to 0 to disable.",
          "minimum": 0,
          "type": "number"
        },
        "goodBranchManager.refreshIntervalMins": {
          "default": 1,
          "description": "Refresh the Branches view in the background every N minutes. Set to 0 to disable periodic refresh. Git repository state changes still refresh automatically.",
          "minimum": 0,
          "type": "number"
        },
        "goodBranchManager.defaultBranch": {
          "default": "",
          "description": "Override the default branch used by the Branches view and pull request form. Leave empty to auto-detect from origin/HEAD, main, master, or HEAD.",
          "type": "string"
        },
        "goodBranchManager.showPrStatus": {
          "default": true,
          "description": "Fetch pull request status from GitHub and show icons for merged/closed/open PRs.",
          "type": "boolean"
        },
        "goodBranchManager.promptForPrOnPublish": {
          "default": true,
          "description": "Ask whether to create a GitHub pull request after the checked-out local branch is published for the first time.",
          "type": "boolean"
        }
      },
      "title": "Branch Manager & PRs"
    },
    "menus": {
      "commandPalette": [
        {
          "command": "goodBranchManager.checkout",
          "when": "false"
        },
        {
          "command": "goodBranchManager.createBranchFrom",
          "when": "false"
        },
        {
          "command": "goodBranchManager.openOnGitHub",
          "when": "false"
        },
        {
          "command": "goodBranchManager.createPullRequest",
          "when": "false"
        },
        {
          "command": "goodBranchManager.renameBranch",
          "when": "false"
        },
        {
          "command": "goodBranchManager.mergeIntoCurrent",
          "when": "false"
        },
        {
          "command": "goodBranchManager.deleteBranch",
          "when": "false"
        },
        {
          "command": "goodBranchManager.pullBranch",
          "when": "false"
        },
        {
          "command": "goodBranchManager.setUpstream",
          "when": "false"
        },
        {
          "command": "goodBranchManager.unsetUpstream",
          "when": "false"
        },
        {
          "command": "goodBranchManager.openPullRequest",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "goodBranchManager.checkout",
          "group": "1_nav@1",
          "when": "view == goodBranchManager.branches && viewItem =~ /branch/ && !(viewItem =~ /current/)"
        },
        {
          "command": "goodBranchManager.createBranchFrom",
          "group": "1_nav@2",
          "when": "view == goodBranchManager.branches && viewItem =~ /branch/"
        },
        {
          "command": "goodBranchManager.openOnGitHub",
          "group": "2_github@1",
          "when": "view == goodBranchManager.branches && viewItem =~ /branch/"
        },
        {
          "command": "goodBranchManager.openPullRequest",
          "group": "2_github@1.5",
          "when": "view == goodBranchManager.branches && viewItem =~ /branch/ && viewItem =~ /has-pr/"
        },
        {
          "command": "goodBranchManager.createPullRequest",
          "group": "2_github@2",
          "when": "view == goodBranchManager.branches && viewItem =~ /branch-local/"
        },
        {
          "command": "goodBranchManager.renameBranch",
          "group": "3_modify@1",
          "when": "view == goodBranchManager.branches && viewItem =~ /branch-local/"
        },
        {
          "command": "goodBranchManager.mergeIntoCurrent",
          "group": "3_modify@2",
          "when": "view == goodBranchManager.branches && viewItem =~ /branch/ && !(viewItem =~ /current/)"
        },
        {
          "command": "goodBranchManager.pullBranch",
          "group": "3_modify@3",
          "when": "view == goodBranchManager.branches && viewItem =~ /branch-local/ && viewItem =~ /current/ && viewItem =~ /upstream/"
        },
        {
          "command": "goodBranchManager.setUpstream",
          "group": "3_modify@4",
          "when": "view == goodBranchManager.branches && viewItem =~ /branch-local/"
        },
        {
          "command": "goodBranchManager.unsetUpstream",
          "group": "3_modify@5",
          "when": "view == goodBranchManager.branches && viewItem =~ /branch-local/ && viewItem =~ /upstream/"
        },
        {
          "command": "goodBranchManager.deleteBranch",
          "group": "4_danger@1",
          "when": "view == goodBranchManager.branches && viewItem =~ /branch/ && !(viewItem =~ /current/)"
        }
      ],
      "view/title": [
        {
          "command": "goodBranchManager.refresh",
          "group": "navigation",
          "when": "view == goodBranchManager.branches"
        }
      ]
    },
    "views": {
      "scm": [
        {
          "contextualTitle": "Branches - GBM",
          "icon": "$(git-branch)",
          "id": "goodBranchManager.branches",
          "name": "Branches - GBM"
        }
      ]
    },
    "viewsWelcome": [
      {
        "contents": "No git repository found in this workspace.\nOpen a folder that contains a git repository to see its branches.",
        "view": "goodBranchManager.branches"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "1.107.0",
    "typescript": "^5.6.0"
  },
  "displayName": "Good Branch Manager",
  "engines": {
    "vscode": "^1.107.0"
  },
  "extensionDependencies": [
    "vscode.git"
  ],
  "scripts": {
    "build": "npm run compile",
    "compile": "node ./node_modules/typescript/lib/tsc.js -p ./",
    "package": "npx @vscode/vsce package",
    "release": "scripts/release.sh",
    "update-lockfile": "npm install --package-lock-only --ignore-scripts",
    "vscode:prepublish": "npm run build",
    "watch": "node ./node_modules/typescript/lib/tsc.js -watch -p ./"
  }
}
